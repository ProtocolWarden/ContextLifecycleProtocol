# Runtime scratch state — never commit
.context/tmp/

# .console — track the editable truth files; ignore regenerated context.
.console/*
!.console/task.md
!.console/guidelines.md
!.console/backlog.md
!.console/log.md

# Operator agent instructions — local, not tracked
CLAUDE.md

.context/active/*.lock
.context/leases/*.live
.context/leases/*.pid

# OS / editor noise
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# Node (if tooling is added later)
node_modules/

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
