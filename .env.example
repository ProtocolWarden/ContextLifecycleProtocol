# ContextLifecycle environment variables (example).
# These are normally set by `eval $(cl session start <manifest>)`, not by hand.

# Absolute path to the anchoring manifest repo whose .context/ holds session state.
CL_ANCHOR=

# Session id minted by `cl session start` (format: s-YYYY-MM-DD-xxxx).
CL_SESSION_ID=

# Optional: override the RepoGraph manifest registry used for anchor resolution.
# REPOGRAPH_REGISTRY=
